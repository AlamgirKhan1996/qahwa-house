# ─────────────────────────────────────────────────────────────
#  Qahwa House · Environment Variables Template
#  Copy this to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://qahwahouse.sa
NEXT_PUBLIC_SITE_NAME="Qahwa House"

# ── Analytics (optional) ───────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Contact Form (optional — replace with your provider) ───
# Uncomment and configure to enable real email sending via
# services like Resend, SendGrid, or AWS SES.
#
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_FORM_TO_EMAIL=hello@qahwahouse.sa
# CONTACT_FORM_FROM_EMAIL=noreply@qahwahouse.sa

# ── Maps (optional) ────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ── Social (for Open Graph preview) ───────────────────────
# NEXT_PUBLIC_TWITTER_HANDLE=@qahwahouse
